# Keep the build context small and, crucially, prevent `COPY . .` from
# clobbering the production node_modules installed during the image build.

node_modules
npm-debug.log*

.git
.gitignore
.dockerignore

# Local runtime config / state (never bake these into the image)
.env
.env.example
stats.json

# Dev-only / docs (not needed at runtime)
docs
scripts
install.sh
README.md

# These describe how to build/run; not needed inside the image
Dockerfile
docker-compose.yml
