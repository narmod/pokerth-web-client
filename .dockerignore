# Keep the build context small and, crucially, prevent `COPY . .` from
# clobbering the production node_modules installed during the image build.

node_modules
npm-debug.log*

.git
.gitignore
.dockerignore

# Local runtime config / state (never bake these into the image)
.env
.env.example
stats.json

# Dev-only / docs (not needed at runtime). scripts/ itself IS needed: the
# admin panel spawns scripts/*-manifest.mjs when importing deck/theme/table
# packs — only the test suites are dev-only.
docs
scripts/test-*.mjs
scripts/build-proto.mjs
install.sh
README.md

# These describe how to build/run; not needed inside the image
Dockerfile
docker-compose.yml
