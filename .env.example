# Copy this file to ".env" (it is read automatically by docker compose) and
# adjust the values for your setup:
#
#   cp .env.example .env
#
# Then: docker compose up -d

# Host port to publish the web client on.
# The container always listens on 8080 internally — this only changes the
# external port you reach it on (e.g. http://your-host:8080/).
PORT=8080

# Comma-separated allowlist of PokerTH servers the proxy is allowed to dial.
# pokerth.net works out of the box. ADD YOUR OWN SERVER, otherwise the proxy
# refuses the connection ("Host not in allowlist").
#
# If your PokerTH server runs on the SAME machine as Docker, use
# host.docker.internal (Docker Desktop) or the host's LAN IP — NOT "localhost",
# which from inside the container points to the container itself.
#
# Example:
# ALLOWED_HOSTS=pokerth.net,www.pokerth.net,host.docker.internal,192.168.1.10,mybox.ddns.net
ALLOWED_HOSTS=pokerth.net,www.pokerth.net

# Comma-separated allowlist of upstream TCP ports the proxy may dial. Standard
# PokerTH servers use 7234, which is always allowed; set this only if your server
# listens on a different port. Second anti-SSRF guard: without it, a request like
# host=127.0.0.1&port=22 could reach local services (SSH, MySQL, ...).
# ALLOWED_PORTS=7234

# ── Family leaderboard reset ──
# How often the shared leaderboard (stats.json) is wiped automatically.
# One of: off | daily | monthly | yearly. Default: monthly.
# The boundary is checked against the SERVER's local time. Per-device session
# stats (stored in each browser) are never affected.
STATS_RESET_PERIOD=monthly

# Optional admin token enabling an on-demand reset of the whole leaderboard:
#   curl -X POST http://your-host:8080/stats \
#        -H 'Content-Type: application/json' \
#        -d '{"_resetAll":true,"token":"YOUR_TOKEN"}'
# Leave empty to disable the endpoint entirely.
# STATS_ADMIN_TOKEN=change-me

# ── Admin panel ──
# Whether the maintainer console at /admin is served. When disabled, /admin and
# every /admin/* route return a plain 404 (fully hidden, not just inert).
# Set to 0 / false / off / no to hide it. Default: enabled.
# With the one-liner installer, prefer `pokerth-web admin on|off`, which persists
# this across updates and reboots.
# ADMIN_ENABLED=1

# ── Optional MySQL / MariaDB mirror ──
# By default the server stores everything it needs in small JSON files - no
# database required. Set MYSQL_HOST and MYSQL_DATABASE to ALSO stream the traffic,
# leaderboard and broadcasts tables into MySQL/MariaDB (the JSON files stay the
# live source of truth; MySQL is written in addition). Tables are created
# automatically on first connect. These variables take precedence over the
# admin-panel / `pokerth-web db-config` settings when set.
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=pokerth
# MYSQL_PASSWORD=change-me
# MYSQL_DATABASE=pokerth

# ── Advanced (rarely needed) ──
# PM2 process name the proxy targets for its self-update / restart actions.
# PM2_NAME=pokerth-web
#
# Override where the server keeps its JSON state files. Each defaults to this
# filename in the install directory; point them at a persistent volume if needed.
# STATS_FILE=stats.json
# STATS_META_FILE=stats.meta.json
# VISITS_FILE=visits.json
# BROADCASTS_FILE=broadcasts.json
# ADMIN_CONFIG_FILE=admin-config.json
# DB_CONFIG_FILE=db-config.json
# SCOPED_TOKENS_FILE=scoped-tokens.json
