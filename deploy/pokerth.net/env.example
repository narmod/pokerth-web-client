# PokerTH Web Client — pokerth.net deployment
# Copied to <repo>/.env by deploy/pokerth.net/install.sh if none exists.

# HTTP port published on the host (nginx proxies to the container by name
# on the shared network, so this is mostly for local debugging).
PORT=8080

# Admin panel at /admin — set a strong token!
ADMIN_ENABLED=1
STATS_ADMIN_TOKEN=CHANGE_ME

# Game servers the proxy may dial (pokerth.net production + test).
ALLOWED_HOSTS=pthsrv.pokerth.net
ALLOWED_PORTS=7234,7236

# Leaderboard reset: off | daily | monthly | yearly
STATS_RESET_PERIOD=monthly
