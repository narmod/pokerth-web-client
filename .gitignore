node_modules/
stats.json
stats.meta.json

# Local environment config (use .env.example as a template)
.env

# User-installed gallery card decks (managed by install.sh deck-add; NOT tracked).
# git pull preserves these untracked folders. svg/ is the built-in vector deck.
/public/cards/*/
!/public/cards/svg/
!/public/cards/pokerth/
!/public/cards/pokerth-new/
!/public/cards/pokerth-1-0/
/public/cards/decks.json

# Background-music: admin-uploaded tracks live untracked (managed from the
# admin panel; git pull preserves them); tracks.json is the built-in seed
# read by the server (currently empty - no audio ships by default).
/public/music/*.mp3

# Runtime, server-owned admin config (reset period, defaults, admin music list…)
admin-config.json

# Scoped delegate API keys (managed by install.sh: pokerth-web token …; chmod 600)
scoped-tokens.json

# Server-generated theme manifest (regenerated by scripts/themes-manifest.mjs on
# install/update; NOT tracked so 'git pull --ff-only' never conflicts on it, like
# decks.json / tables.json above).
/public/themes/themes.json
