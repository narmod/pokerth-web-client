{
  "name": "pokerth-web-client",
  "version": "0.3.833-beta",
  "description": "Experimental modern web client for PokerTH using a WebSocket-to-TCP proxy.",
  "main": "proxy.js",
  "private": false,
  "scripts": {
    "start": "node proxy.js",
    "start:lan": "node proxy.js --notls",
    "start:insecure": "node proxy.js --insecure",
    "build:proto": "node scripts/build-proto.mjs",
    "stats:reset": "node scripts/reset-stats.mjs",
    "test:phe": "node scripts/test-phe.mjs",
    "test:bots": "node scripts/test-bots.mjs",
    "test:cards": "node scripts/test-cards.mjs",
    "test:proto": "node scripts/test-proto.mjs",
    "test:crypto": "node scripts/test-crypto.mjs",
    "test:messages": "node scripts/test-messages.mjs",
    "test:shortcuts": "node scripts/test-shortcuts.mjs",
    "test:reactions": "node scripts/test-reactions.mjs",
    "test:anim": "node scripts/test-anim.mjs",
    "test:seats": "node scripts/test-seats.mjs",
    "test:layout": "node scripts/test-layout.mjs",
    "test:deck": "node scripts/test-deck.mjs",
    "test:avatar-cache": "node scripts/test-avatar-cache.mjs",
    "test:misc": "node scripts/test-misc.mjs",
    "test:state": "node scripts/test-state.mjs"
  },
  "keywords": [
    "pokerth",
    "poker",
    "texas-holdem",
    "websocket",
    "web-client",
    "protobuf"
  ],
  "author": "Arnaud Obscur",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "dotenv": "^17.4.2",
    "mysql2": "^3.6.0",
    "pino": "^10.3.1",
    "rate-limiter-flexible": "^11.2.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "protobufjs": "^8.4.2",
    "protobufjs-cli": "^2.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
